# Tally ODBC Data Source Name (configured in Windows ODBC Administrator)
TALLY_DSN=TallyODBC_9000

# CredFloat cloud API endpoint + shared secret
CREDFLOAT_API_URL=http://localhost:3000/api/sync
CREDFLOAT_API_KEY=change-me-once-backend-is-up

# Set to "true" for local testing — prints the payload instead of pushing.
# Flip to "false" once the cloud backend is ready to receive.
DRY_RUN=true
