// CredFloat Database Schema
// Prisma 5.x + PostgreSQL (Supabase)
//
// Setup:
//   1. npx prisma init
//   2. Replace prisma/schema.prisma with this file
//   3. Set DATABASE_URL in .env (Supabase Postgres connection string)
//   4. npx prisma migrate dev --name init
//   5. npx prisma generate
//
// Design notes:
//   - Multi-tenant at the Firm level. Every query must filter by firmId.
//     For V1 there's only DPS & Co, but the schema is ready for Phase 3 SaaS.
//   - Soft boundaries: deleting a ClientCompany cascades to its parties/invoices.
//   - All money stored as Decimal(15, 2) — safe up to ₹99,99,99,99,999.99.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// -------------------------------------------------------------------
// Firm — the CA firm operating CredFloat (just DPS & Co in V1)
// -------------------------------------------------------------------
model Firm {
  id              String           @id @default(cuid())
  name            String
  createdAt       DateTime         @default(now())

  // Letterhead / signatory block used on ledger-statement PDFs.
  // Indian CA firms need FRN (Firm Registration Number with ICAI) and
  // the signing partner's name + M.No. (ICAI membership number).
  frn             String?
  partnerName     String?
  partnerMno      String?

  // Bank + UPI details rendered on the reminder email and the ledger
  // PDF so the debtor can pay in-line instead of hunting for account
  // info. UPI VPA drives a QR (upi://pay?pa=...&pn=...&am=...).
  bankName            String?
  bankAccountName     String?
  bankAccountNumber   String?
  bankIfsc            String?
  upiId               String?

  staff           FirmStaff[]
  clientCompanies ClientCompany[]
}

// -------------------------------------------------------------------
// FirmStaff — users who log into the dashboard
// -------------------------------------------------------------------
model FirmStaff {
  id           String   @id @default(cuid())
  firm         Firm     @relation(fields: [firmId], references: [id], onDelete: Cascade)
  firmId       String
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(STAFF)
  createdAt    DateTime @default(now())

  notes          Note[]
  promisesLogged PromiseToPay[]
  savedViews     SavedView[]
  portalTokens   PortalToken[]

  @@index([firmId])
}

enum Role {
  PARTNER // sees all clients
  STAFF   // sees assigned clients (Phase 2: assignment table)
}

// -------------------------------------------------------------------
// ClientCompany — the 300+ SMEs whose Tally data the firm manages
// -------------------------------------------------------------------
model ClientCompany {
  id               String        @id @default(cuid())
  firm             Firm          @relation(fields: [firmId], references: [id], onDelete: Cascade)
  firmId           String
  tallyCompanyName String // exact name as it appears in Tally
  displayName      String // friendly name for dashboard
  status           CompanyStatus @default(ACTIVE)

  parties        Party[]
  invoices       Invoice[]
  receipts       Receipt[]
  reminderRules  ReminderRule[]
  notes          Note[]
  portalTokens   PortalToken[]
  ledgerEntries  LedgerEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([firmId, tallyCompanyName])
  @@index([firmId])
}

enum CompanyStatus {
  ACTIVE
  PAUSED   // temporarily stop sending reminders for this client
  ARCHIVED
}

// -------------------------------------------------------------------
// Party — debtors (sundry debtor ledgers from Tally)
// -------------------------------------------------------------------
model Party {
  id              String         @id @default(cuid())
  clientCompany   ClientCompany  @relation(fields: [clientCompanyId], references: [id], onDelete: Cascade)
  clientCompanyId String
  tallyLedgerName String
  parentGroup     String

  // Contact info — often incomplete in Tally, flag for enrichment
  mailingName     String?
  address         String?
  phone           String?
  email           String?
  whatsappNumber  String?
  contactVerified Boolean        @default(false)

  // Outstanding balance from latest sync
  closingBalance  Decimal        @db.Decimal(15, 2)

  // Opening balance carried forward from prior FY — from Tally's
  // Ledger master (ODBC $OpeningBalance). Drives the drill-down's
  // "Opening balance" row so our numbers match Tally's day book.
  openingBalance  Decimal        @db.Decimal(15, 2) @default(0)

  // Net unallocated receipts (excess payments not yet applied to any bill).
  // Maintained by the allocation engine on each sync; positive when the
  // debtor has paid more than the sum of their current open bills.
  advanceAmount   Decimal        @db.Decimal(15, 2) @default(0)

  // Opt-out: debtor replied STOP to any channel
  optedOut        Boolean        @default(false)
  optedOutReason  String?

  invoices        Invoice[]
  receipts        Receipt[]
  ledgerEntries   LedgerEntry[]
  remindersSent   ReminderSent[]
  notes           Note[]
  promises        PromiseToPay[]

  lastSyncedAt    DateTime
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([clientCompanyId, tallyLedgerName])
  @@index([clientCompanyId])
  @@index([optedOut])
}

// -------------------------------------------------------------------
// Invoice — bill-wise outstanding entries from Tally
// -------------------------------------------------------------------
model Invoice {
  id                String         @id @default(cuid())
  clientCompany     ClientCompany  @relation(fields: [clientCompanyId], references: [id], onDelete: Cascade)
  clientCompanyId   String
  party             Party          @relation(fields: [partyId], references: [id], onDelete: Cascade)
  partyId           String

  billRef           String // Tally bill reference (e.g. "INV-2024-0142")
  billDate          DateTime
  dueDate           DateTime? // derived from billDate + credit terms
  originalAmount    Decimal        @db.Decimal(15, 2)
  outstandingAmount Decimal        @db.Decimal(15, 2)

  status            InvoiceStatus  @default(OPEN)
  ageBucket         AgeBucket      @default(CURRENT) // recomputed daily

  remindersSent     ReminderSent[]
  allocations       ReceiptAllocation[]

  lastSyncedAt      DateTime
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@unique([clientCompanyId, partyId, billRef])
  @@index([clientCompanyId, status])
  @@index([partyId])
  @@index([ageBucket])
  @@index([dueDate])
}

enum InvoiceStatus {
  OPEN
  PAID
  DISPUTED // manually flagged by staff; reminders paused
}

enum AgeBucket {
  CURRENT      // not yet due
  DAYS_0_30
  DAYS_30_60
  DAYS_60_90
  DAYS_90_PLUS
}

// -------------------------------------------------------------------
// Receipt — payments received, for matching against invoices
// -------------------------------------------------------------------
model Receipt {
  id              String        @id @default(cuid())
  clientCompany   ClientCompany @relation(fields: [clientCompanyId], references: [id], onDelete: Cascade)
  clientCompanyId String
  party           Party         @relation(fields: [partyId], references: [id], onDelete: Cascade)
  partyId         String

  voucherRef      String // Tally voucher number
  receiptDate     DateTime
  amount          Decimal       @db.Decimal(15, 2)

  allocations     ReceiptAllocation[]

  lastSyncedAt    DateTime
  createdAt       DateTime      @default(now())

  @@unique([clientCompanyId, voucherRef])
  @@index([partyId])
}

// -------------------------------------------------------------------
// ReceiptAllocation — how much of each Receipt was applied to which
// Invoice. Either sourced from Tally's BILLALLOCATIONS on the receipt
// voucher (TALLY_BILLWISE), derived by our FIFO engine when the
// receipt was posted on-account (FIFO_DERIVED), or manually adjusted
// by staff (MANUAL — preserved across syncs).
// -------------------------------------------------------------------
model ReceiptAllocation {
  id          String           @id @default(cuid())
  receipt     Receipt          @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  receiptId   String
  invoice     Invoice          @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId   String

  amount      Decimal          @db.Decimal(15, 2)
  source      AllocationSource

  allocatedAt DateTime         @default(now())
  createdAt   DateTime         @default(now())

  @@unique([receiptId, invoiceId])
  @@index([receiptId])
  @@index([invoiceId])
  @@index([source])
}

enum AllocationSource {
  TALLY_BILLWISE  // Tally voucher had BILLALLOCATIONS with this bill ref
  FIFO_DERIVED    // our engine applied this allocation on-account
  MANUAL          // staff override — engine will not overwrite
}

// -------------------------------------------------------------------
// ReminderRule — per-client configuration of the reminder schedule
// -------------------------------------------------------------------
model ReminderRule {
  id                 String        @id @default(cuid())
  clientCompany      ClientCompany @relation(fields: [clientCompanyId], references: [id], onDelete: Cascade)
  clientCompanyId    String

  name               String        @default("Default")
  enabled            Boolean       @default(true)

  // Trigger offsets in days relative to invoice due date.
  // Negative = before due date. e.g. [-3, 0, 7, 14, 30]
  triggerDays        Int[]

  channels           Channel[] // which channels are active for this rule

  emailTemplate      String?
  smsTemplate        String?
  whatsappTemplateId String? // Meta-approved template ID (not raw text)

  // Ledger statement PDF attached to reminders.
  //   attachLedger      — turn the attachment on/off for this client
  //   ledgerPeriodType  — how the statement's window is computed
  //   ledgerPeriodStart — explicit window (only for CUSTOM)
  //   ledgerPeriodEnd   — explicit window (only for CUSTOM)
  attachLedger       Boolean            @default(true)
  ledgerPeriodType   LedgerPeriodType   @default(FY_TO_DATE)
  ledgerPeriodStart  DateTime?
  ledgerPeriodEnd    DateTime?

  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([clientCompanyId])
}

enum LedgerPeriodType {
  FY_TO_DATE       // 1 Apr of current Indian FY → today
  LAST_12_MONTHS   // today − 365d → today
  OPEN_ITEMS_ONLY  // only currently-open bills, no time bound
  ALL_HISTORY      // everything we have
  CUSTOM           // honours ledgerPeriodStart / End
}

enum Channel {
  EMAIL
  SMS
  WHATSAPP
}

// -------------------------------------------------------------------
// ReminderSent — audit log of every reminder dispatched
// -------------------------------------------------------------------
model ReminderSent {
  id         String     @id @default(cuid())
  party      Party      @relation(fields: [partyId], references: [id], onDelete: Cascade)
  partyId    String
  invoice    Invoice    @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId  String

  channel    Channel
  sentAt     DateTime   @default(now())

  providerId String? // external message ID (WhatsApp message_id, SMS request_id, etc.)
  status     SendStatus @default(SENT)
  error      String?

  @@index([partyId])
  @@index([invoiceId])
  @@index([sentAt])
}

enum SendStatus {
  SENT
  DELIVERED
  READ
  FAILED
  BOUNCED
}

// -------------------------------------------------------------------
// Note — partner/staff free-text notes on clients or debtors
// -------------------------------------------------------------------
model Note {
  id              String         @id @default(cuid())
  clientCompany   ClientCompany  @relation(fields: [clientCompanyId], references: [id], onDelete: Cascade)
  clientCompanyId String
  party           Party?         @relation(fields: [partyId], references: [id], onDelete: Cascade)
  partyId         String?
  author          FirmStaff      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId        String
  body            String
  createdAt       DateTime       @default(now())

  @@index([clientCompanyId])
  @@index([partyId])
  @@index([createdAt])
}

// -------------------------------------------------------------------
// PromiseToPay — debtor said "I'll pay X by Y"; tracks kept/broken
// -------------------------------------------------------------------
model PromiseToPay {
  id          String         @id @default(cuid())
  party       Party          @relation(fields: [partyId], references: [id], onDelete: Cascade)
  partyId     String
  amount      Decimal        @db.Decimal(15, 2)
  promisedBy  DateTime
  recorder    FirmStaff      @relation(fields: [recordedBy], references: [id], onDelete: Cascade)
  recordedBy  String
  recordedAt  DateTime       @default(now())
  status      PromiseStatus  @default(OPEN)
  notes       String?

  @@index([partyId])
  @@index([status])
  @@index([promisedBy])
}

enum PromiseStatus {
  OPEN
  KEPT
  BROKEN
}

// -------------------------------------------------------------------
// SavedView — named filter URL partners pin to their sidebar
// -------------------------------------------------------------------
model SavedView {
  id        String   @id @default(cuid())
  owner     FirmStaff @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId   String
  name      String
  path      String
  params    String
  createdAt DateTime @default(now())

  @@index([ownerId])
}

// -------------------------------------------------------------------
// ActivityLog — append-only audit trail, DPDP-grade
// -------------------------------------------------------------------
model ActivityLog {
  id         String   @id @default(cuid())
  firmId     String
  actorId    String?
  action     String
  targetType String
  targetId   String
  meta       Json?
  createdAt  DateTime @default(now())

  @@index([firmId, createdAt])
  @@index([targetType, targetId])
  @@index([actorId])
}

// -------------------------------------------------------------------
// PortalToken — signed read-only magic-link for a client
// -------------------------------------------------------------------
model PortalToken {
  id              String         @id @default(cuid())
  clientCompany   ClientCompany  @relation(fields: [clientCompanyId], references: [id], onDelete: Cascade)
  clientCompanyId String
  token           String         @unique
  creator         FirmStaff      @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  createdBy       String
  createdAt       DateTime       @default(now())
  expiresAt       DateTime?
  revokedAt       DateTime?
  lastUsedAt      DateTime?

  @@index([clientCompanyId])
  @@index([token])
}

// -------------------------------------------------------------------
// LedgerEntry — full Tally Day Book, one row per voucher-line that
// touches a debtor ledger. Drives the drill-down view so every
// number matches Tally 1:1 (opening balance + running balance).
// -------------------------------------------------------------------
model LedgerEntry {
  id              String        @id @default(cuid())
  party           Party         @relation(fields: [partyId], references: [id], onDelete: Cascade)
  partyId         String
  clientCompany   ClientCompany @relation(fields: [clientCompanyId], references: [id], onDelete: Cascade)
  clientCompanyId String

  voucherDate     DateTime
  voucherType     VoucherType
  voucherRef      String        // Tally VoucherNumber (or synthesized)
  // Other side of the entry — "TAXABLE @ 18% SALE", "INDUSIND BANK", etc.
  // Empty string (not null) so the unique key below treats two entries
  // with no counterparty as colliding rows, preventing duplicates.
  counterparty    String        @default("")
  narration       String?

  /** Rupees. Only one of debit/credit is non-zero per row. */
  debit           Decimal       @db.Decimal(15, 2) @default(0)
  credit          Decimal       @db.Decimal(15, 2) @default(0)

  lastSyncedAt    DateTime
  createdAt       DateTime      @default(now())

  // One voucher can touch the same party multiple times (split bills).
  // Uniqueness: (company, voucher, type, party, counterparty) — tight
  // enough to dedupe across syncs without collapsing split entries.
  @@unique([clientCompanyId, voucherRef, voucherType, partyId, counterparty])
  @@index([partyId, voucherDate])
  @@index([clientCompanyId, voucherDate])
  @@index([voucherType])
}

enum VoucherType {
  SALES
  PURCHASE
  RECEIPT
  PAYMENT
  JOURNAL
  CONTRA
  CREDIT_NOTE
  DEBIT_NOTE
  STOCK_JOURNAL
  OTHER
}
