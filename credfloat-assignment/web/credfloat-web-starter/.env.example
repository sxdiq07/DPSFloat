# -------- Database (Supabase) --------
# Get these from Supabase Dashboard -> Project Settings -> Database -> Connection string
# DATABASE_URL uses the transaction pooler (port 6543) for app queries
# DIRECT_URL uses the direct connection (port 5432) for Prisma migrations
DATABASE_URL="postgresql://postgres.xxxxxxx:YOUR-PASSWORD@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxxxxx:YOUR-PASSWORD@aws-0-ap-south-1.pooler.supabase.com:5432/postgres"

# -------- Auth --------
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-me-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# -------- Shared secrets --------
# Used by Python Tally connector when POSTing to /api/sync
SYNC_API_KEY="dps-credfloat-sync-change-me-to-long-random-string"

# Used by Vercel Cron when calling cron endpoints
CRON_SECRET="dps-credfloat-cron-change-me-to-long-random-string"

# -------- Email (Resend) --------
# Sign up at https://resend.com — free tier is 3,000 emails/month
# Leave RESEND_FROM as onboarding@resend.dev until you verify your own domain
RESEND_API_KEY=""
RESEND_FROM="onboarding@resend.dev"
# Svix secret for Resend webhook signature verification. Copy from the
# Resend dashboard after adding /api/webhooks/resend as an endpoint.
# Leave blank in dev — requests will be accepted unsigned.
RESEND_WEBHOOK_SECRET=""

# Base URL used in outgoing links (password reset, public ledger PDFs).
# Defaults to NEXTAUTH_URL if unset.
APP_URL="http://localhost:3000"

# -------- WhatsApp (Meta Cloud API) --------
# Setup: https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
# Use the free test number for demo (5 recipients max). Leave blank to stub.
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""

# -------- Seed demo user --------
SEED_FIRM_NAME="DPS & Co"
SEED_DEMO_EMAIL="demo@dpsandco.in"
SEED_DEMO_PASSWORD="dps2026"
